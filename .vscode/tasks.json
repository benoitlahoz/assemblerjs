		{
			"label": "audit-internal-version-alignment",
			"type": "shell",
			"command": "node",
			"args": [
				"-e",
				"const fs=require('fs');const path=require('path');let semver=null;try{semver=require('semver')}catch{};const root=process.cwd();const scopes=['packages','examples'];const manifests=[];for(const scope of scopes){const scopeDir=path.join(root,scope);if(!fs.existsSync(scopeDir))continue;for(const name of fs.readdirSync(scopeDir)){const pkgPath=path.join(scopeDir,name,'package.json');if(fs.existsSync(pkgPath)){const json=JSON.parse(fs.readFileSync(pkgPath,'utf8'));manifests.push({pkgPath:path.relative(root,pkgPath),dir:path.join(scope,name),name:json.name,version:json.version,json});}}}const byName=new Map(manifests.filter(m=>m.name&&m.version).map(m=>[m.name,m.version]));const depFields=['dependencies','devDependencies','peerDependencies','optionalDependencies'];const issues=[];for(const m of manifests){for(const field of depFields){const deps=m.json[field]||{};for(const [dep,spec] of Object.entries(deps)){if(!byName.has(dep))continue;const latest=byName.get(dep);let isAligned=false; if(spec===latest)isAligned=true; else if(semver){ try{ const min=semver.minVersion(spec); if(min && semver.gte(min, latest) && semver.satisfies(latest,spec)) isAligned=true; else if(semver.satisfies(latest,spec)) isAligned=true; }catch{} } else { if(String(spec).includes(latest)) isAligned=true; } if(!isAligned){issues.push({consumer:m.name,consumerPath:m.pkgPath,field,dep,spec,latest});}}}}console.log('INTERNAL_PACKAGE_VERSIONS');for(const m of manifests.sort((a,b)=>a.name.localeCompare(b.name))){console.log(`${m.name}@${m.version} <- ${m.pkgPath}`);}console.log('\\nMISMATCHES');if(!issues.length){console.log('NONE');}else{for(const i of issues){console.log(`${i.consumer} (${i.consumerPath}) :: ${i.field} -> ${i.dep}@${i.spec} (latest local: ${i.latest})`);}}"
			],
			"isBackground": false
		},
