{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["src/*"],
      "@assemblerjs/common": ["../common/src/index.ts"],
      "@assemblerjs/common/*": ["../common/src/*"]
    },
    "types": ["node", "vite/client", "reflect-metadata"]
  },
  "include": ["src/**/*.ts", "index.d.ts"],
  "references": [
    {
      "path": "../assemblerjs/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    },
    {
      "path": "../common/tsconfig.lib.json"
    }
  ],
  "exclude": [
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx"
  ]
}
