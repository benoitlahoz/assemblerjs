{
  "name": "@assemblerjs/openapi",
  "description": "OpenAPI decorators for AssemblerJS REST APIs.",
  "version": "0.9.0",
  "author": "Benoît LAHOZ <info@benoitlahoz.io>",
  "bugs": "https://github.com/benoitlahoz/assemblerjs/issues",
  "homepage": "https://github.com/benoitlahoz/assemblerjs#README",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoitlahoz/assemblerjs.git"
  },
  "keywords": [
    "assemblerjs",
    "openapi",
    "swagger",
    "api",
    "decorator",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@assemblerjs/core": "0.9.9"
  },
  "devDependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
