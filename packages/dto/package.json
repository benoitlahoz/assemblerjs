{
  "name": "@assemblerjs/dto",
  "description": "Data Transfer Object decorators for AssemblerJS with validation and transformation.",
  "version": "1.0.1",
  "author": "Benoît LAHOZ <info@benoitlahoz.io>",
  "bugs": "https://github.com/benoitlahoz/assemblerjs/issues",
  "homepage": "https://github.com/benoitlahoz/assemblerjs#README",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoitlahoz/assemblerjs.git"
  },
  "keywords": [
    "assemblerjs",
    "dto",
    "validation",
    "transformation",
    "decorator",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@assemblerjs/common": "1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2"
  }
}
