{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest"
    ],
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@/*": ["./src/*"],
      "@assemblerjs/common": ["../common/src/index.ts"],
      "@assemblerjs/common/*": ["../common/src/*"]
    }
  },
  "include": [
    "vite.config.mts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "e2e/**/*.ts",
    "e2e/fixtures/**/*.ts",
    "e2e/**/*.test.ts",
    "e2e/**/*.spec.ts",
    "e2e/**/*.test.tsx",
    "e2e/**/*.spec.tsx",
    "e2e/**/*.test.js",
    "e2e/**/*.spec.js",
    "e2e/**/*.test.jsx",
    "e2e/**/*.spec.jsx"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
