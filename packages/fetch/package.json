{
  "name": "@assemblerjs/fetch",
  "description": "HTTP client decorators for AssemblerJS.",
  "version": "1.0.1",
  "author": "Benoît LAHOZ <info@benoitlahoz.io>",
  "bugs": "https://github.com/benoitlahoz/assemblerjs/issues",
  "homepage": "https://github.com/benoitlahoz/assemblerjs#README",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoitlahoz/assemblerjs.git"
  },
  "keywords": [
    "assemblerjs",
    "fetch",
    "http",
    "client",
    "decorator",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@assemblerjs/common": "1.0.1",
    "@assemblerjs/core": "0.9.9"
  },
  "devDependencies": {
    "assemblerjs": "1.2.1",
    "reflect-metadata": "^0.2.2"
  }
}
