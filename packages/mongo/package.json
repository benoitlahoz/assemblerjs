{
  "name": "@assemblerjs/mongo",
  "version": "0.9.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "comments": {
    "dependencies": "assemblerjs dependencies not used for the time being, but we want to keep them in case we need to use them in the future. Also, we want to keep the versions in sync with the rest of the packages."
  },
  "dependencies": {
    "@assemblerjs/core": "0.9.8",
    "assemblerjs": "1.2.1",
    "mongoose": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "mongoose-delete": "^1.0.2"
  }
}
