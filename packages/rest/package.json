{
  "name": "@assemblerjs/rest",
  "description": "REST API decorators for AssemblerJS with Express and Fastify support.",
  "version": "1.1.3",
  "author": "Benoît LAHOZ <info@benoitlahoz.io>",
  "bugs": "https://github.com/benoitlahoz/assemblerjs/issues",
  "homepage": "https://github.com/benoitlahoz/assemblerjs#README",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benoitlahoz/assemblerjs.git"
  },
  "keywords": [
    "assemblerjs",
    "rest",
    "api",
    "express",
    "fastify",
    "decorator",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "import": "./dist/express.js",
      "require": "./dist/express.cjs"
    },
    "./fastify": {
      "types": "./dist/fastify.d.ts",
      "import": "./dist/fastify.js",
      "require": "./dist/fastify.cjs"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@assemblerjs/common": "1.0.1",
    "@assemblerjs/core": "0.9.9",
    "@assemblerjs/dto": "1.0.1",
    "assemblerjs": "1.2.1"
  },
  "peerDependencies": {
    "express": ">=5.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "express": "5.1.0",
    "fastify": "^5.0.0",
    "reflect-metadata": "^0.2.2",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.6"
  }
}
