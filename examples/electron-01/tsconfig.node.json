{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "files": [
    "src/renderer/src/composables/useContext.ts",
    "src/renderer/src/composables/useIpc.ts",
    "src/renderer/src/composables/useSystem.ts",
    "src/renderer/src/composables/useWindows.ts"
  ],
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/renderer/src/composables/**/*",
    "src/common/**/*",
    "src/features/**/*",
    "src/windows/**/*",
    "src/windows/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noUnusedLocals": false,
    "types": ["electron-vite/node"],
    "paths": {
      "@renderer/*": ["src/renderer/src/*"],
      "@common/*": ["src/common/*"],
      "@features/*": ["src/features/*"],
      "@windows/*": ["src/windows/*"],
      "@preload/*": ["src/preload/*"]
    }
  }
}
